set -e

SERVICE_NAME="aenigma"
APP_USER="aenigma"
APP_INSTALL_DIR="/usr/local/$SERVICE_NAME"
CONFIG_DIR="/usr/local/etc/$SERVICE_NAME"
VAR_LIB="/var/lib/$SERVICE_NAME"
LOGS_DIR="/var/log/$SERVICE_NAME"
UPLOADS_DIR="/srv/$SERVICE_NAME"
SERVICE_FILE="/etc/systemd/system/$SERVICE_NAME.service"

ACTION="${1:-}"

log() {
  printf '%s\n' "$*"
}

safe_rm_dir() {
  DIR="$1"

  [ -n "$DIR" ] || return 0
  [ -d "$DIR" ] || return 0

  # refuse symlinks
  if [ -L "$DIR" ]; then
    log "Refusing to remove symlink: $DIR"
    return 1
  fi

  # refuse dangerous paths
  case "$DIR" in
    /|/usr|/usr/local|/etc|/var|/bin|/sbin|/lib|/lib64)
      log "Refusing to remove protected path: $DIR"
      return 1
      ;;
  esac

  log "Removing directory: $DIR"
  rm -rf --one-file-system "$DIR"
}

safe_rm_file() {
  FILE="$1"
  log "Removing file: $FILE"
  [ -n "$FILE" ] && [ -f "$FILE" ] && rm -f "$FILE"
}

stop_service() {
  if command -v systemctl >/dev/null 2>&1 &&
     systemctl list-unit-files | grep -q "^$SERVICE_NAME.service"; then
    log "Stopping and disabling $SERVICE_NAME.service"
    systemctl stop "$SERVICE_NAME.service" 2>/dev/null || true
    systemctl disable "$SERVICE_NAME.service" 2>/dev/null || true
  fi
}

remove_symlinks() {
  log "Removing symlinks from /usr/local/bin"
  find /usr/local/bin \
    -maxdepth 1 \
    -type l \
    -name "$SERVICE_NAME-*" \
    -print \
    -delete || true
}

remove_user() {
  if id "$APP_USER" >/dev/null 2>&1; then
    log "Removing user $APP_USER"
    deluser --remove-home "$APP_USER" || true
  fi
}

case "$ACTION" in
  remove)
    stop_service
    remove_symlinks
    safe_rm_dir "$APP_INSTALL_DIR"
    ;;

  purge)
    stop_service
    remove_symlinks

    safe_rm_dir "$APP_INSTALL_DIR"
    safe_rm_dir "$CONFIG_DIR"
    safe_rm_dir "$VAR_LIB"
    safe_rm_dir "$LOGS_DIR"
    safe_rm_dir "$UPLOADS_DIR"

    safe_rm_file "$SERVICE_FILE"
    remove_user
    ;;

  upgrade|abort-upgrade|failed-upgrade)
    log "Upgrade path detected: no cleanup required"
    ;;

  *)
    log "postrm called with unknown action: $ACTION"
    ;;
esac

exit 0
