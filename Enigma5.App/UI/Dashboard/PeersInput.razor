@rendermode InteractiveServer

@using Enigma5.App.Models
@using Enigma5.App.UI.Common

<div class="card card-shadow">
    <div class="card-body">
        <ItemsList Items="Items">
            <PeerItem Model="context" OnRemove="OnRemoveItem" />
        </ItemsList>
        <div class="row">
            <div class="col col-6">
                <label for="host-input">Host</label>
                <InputText id="host-input" class="form-control" @bind-Value="Host" />
            </div>
            <div class="col col-5">
                <label for="address-input">Address</label>
                <InputText id="address-input" class="form-control" @bind-Value="Address" />
            </div>
            <div class="col col-1 d-flex align-items-end justify-content-center">
                <button class="btn btn-primary" @onclick="AddItem">Add</button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public IEnumerable<Peer> Items { get; set; } = [];
    [Parameter] public EventCallback<Peer> OnAddItem { get; set; } = default;
    [Parameter] public EventCallback<Peer> OnRemoveItem { get; set; } = default;

    private string Host = string.Empty;
    private string Address = string.Empty;

    private Task AddItem()
    {
        if (string.IsNullOrEmpty(Host) || string.IsNullOrWhiteSpace(Address))
        {
            return Task.CompletedTask;
        }
        var newPeer = new Peer
        {
            Host = Host,
            Address = Address
        };
        ResetInput();
        return OnAddItem.InvokeAsync(newPeer);
    }

    private void ResetInput()
    {
        Host = string.Empty;
        Address = string.Empty;
    }
}
