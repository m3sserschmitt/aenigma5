set -e

SERVICE_NAME="aenigma"
SERVICE_USER="aenigma"
APP_INSTALL_DIR="/usr/local/$SERVICE_NAME"
LAUNCHER_FILE="/usr/local/bin/$SERVICE_NAME-launcher"
SERVICE_FILE="/etc/systemd/system/$SERVICE_NAME.service"
LOG_DIR="/var/log/$SERVICE_NAME"
CONFIGS_DIR="/usr/local/etc/$SERVICE_NAME"
CONFIG_FILE="$CONFIGS_DIR/appsettings.json"
SRV_DIR="/srv/$SERVICE_NAME"
UPLOADS_DIR="$SRV_DIR/uploads"
LIB_DIR="/var/lib/$SERVICE_NAME"
DATABASE_DIR="$LIB_DIR/db"
SCRIPTS_DIR="$APP_INSTALL_DIR/Scripts"

filename_without_ext() {
    local fullpath="$1"
    local filename="${fullpath##*/}"
    echo "${filename%.*}"
}

if ! id "$SERVICE_USER" &>/dev/null; then
    echo "Creating user '$SERVICE_USER' for the service... "
    useradd --system --no-create-home --shell /usr/sbin/nologin "$SERVICE_USER"
fi

mkdir -pv "$LOG_DIR"
mkdir -pv "$LIB_DIR"
mkdir -pv "$DATABASE_DIR"
mkdir -pv "$SRV_DIR"
mkdir -pv "$UPLOADS_DIR"
mkdir -pv "$CONFIGS_DIR"

if [ ! -f "$CONFIG_FILE" ]; then
    echo "Copying configuration file to $CONFIG_FILE..."
    mkdir -pv $CONFIGS_DIR
    cp -v $APP_INSTALL_DIR/appsettings.json $CONFIG_FILE
fi

if [ ! -f "$SERVICE_FILE" ]; then
    echo "Creating service file: $SERVICE_FILE..."
    cat <<EOF | tee $SERVICE_FILE > /dev/null
    [Unit]
    Description=$SERVICE_NAME Service
    After=network.target

    [Service]
    WorkingDirectory=$APP_INSTALL_DIR
    ExecStart=$LAUNCHER_FILE
    Restart=always
    RestartSec=10
    User=$SERVICE_USER
    Group=$SERVICE_USER

    [Install]
    WantedBy=multi-user.target
EOF
fi

chown -R "$SERVICE_USER":"$SERVICE_USER" "$LOG_DIR"
chmod -v 755 "$LOG_DIR"

chown -R "$SERVICE_USER":"$SERVICE_USER" "$APP_INSTALL_DIR"
chmod -R 700 "$APP_INSTALL_DIR"

chown -R "$SERVICE_USER":"$SERVICE_USER" "$LIB_DIR"
chmod -R 700 "$LIB_DIR"

chown -R "$SERVICE_USER":"$SERVICE_USER" "$SRV_DIR"
chmod -R 700 "$SRV_DIR"

chown -R "$SERVICE_USER":"$SERVICE_USER" "$CONFIGS_DIR"
chmod -R 700 "$CONFIGS_DIR"

chown -R "$SERVICE_USER":"$SERVICE_USER" "$SCRIPTS_DIR"
chmod -R 755 "$SCRIPTS_DIR"

for f in "$APP_INSTALL_DIR"/Scripts/*.sh; do
    [ -e "$f" ] || continue
    chmod -v +x "$f"

    link_name="/usr/local/bin/$(filename_without_ext "$f")"
    ln -sfv "$f" "$link_name"
done

echo "Done."
