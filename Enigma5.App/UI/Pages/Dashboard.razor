@using Enigma5.App.Models
@using Enigma5.App.Resources.Commands
@using Enigma5.App.Resources.Handlers
@using Enigma5.App.Resources.Queries
@using Enigma5.App.UI.Common
@using Enigma5.App.UI.Dashboard
@using Enigma5.Security.Contracts
@using System.Collections.Immutable
@using System.Text
@using MediatR

@page "/Dashboard"
@rendermode InteractiveServer
@implements IDisposable

@inject IMediator Mediator
@inject DashboardUIState DashboardUIState

<div class="row justify-content-center h-100">
    <div class="d-flex flex-column justify-content-between col col-3 ">
        <PassphraseInput OnUnlockKey="UnlockPrivateKey" OnLockKey="LockPrivateKey"/>
        <ExportContactDataQrCode />
    </div>
    <div class="col col-9">
        <PeersInput Items="Peers" OnAddItem="SubmitNewPeer" OnRemoveItem="RemovePeer" OnRetry="ReloadPeerConnections"/>
    </div>
</div>

@code {
    private IEnumerable<PeerDto> Peers = [];

    protected override Task OnInitializedAsync()
    {
        DashboardUIState.OnInboundPeersChanged += OnPeersChanged;
        DashboardUIState.OnOutboundPeersChanged += OnPeersChanged;
        return InvokeAsync(LoadPeers);
    }

    private void OnPeersChanged(HashSet<PeerDto> peers) => InvokeAsync(LoadPeers);

    private Task LoadPeers()
    {
        lock (DashboardUIState.OutboundPeers)
        {
            lock (DashboardUIState.InboundPeers)
            {
                var result = new HashSet<PeerDto>(DashboardUIState.OutboundPeers);
                foreach (var outboundPeer in DashboardUIState.OutboundPeers)
                {
                    outboundPeer.Connected = DashboardUIState.InboundPeers.TryGetValue(outboundPeer, out var _);
                    result.Add(outboundPeer);
                }
                Peers = result.Union(DashboardUIState.InboundPeers);
            }
        }
        return InvokeAsync(StateHasChanged);
    }

    private async Task SubmitNewPeer(PeerDto peer)
    {
        if (string.IsNullOrWhiteSpace(peer.Host) || string.IsNullOrWhiteSpace(peer.Address))
        {
            return;
        }
        var result = await Mediator.Send(new AddPeerCommand(peer.Host, peer.Address));
        if (result.IsSuccessNotNullResultValue())
        {
            await InvokeAsync(LoadPeers);
        }
    }

    private async Task RemovePeer(PeerDto peer)
    {
        if (peer.Id == null)
        {
            return;
        }
        var result = await Mediator.Send(new RemovePeerCommand(peer.Id.Value));
        if (result.IsSuccessNotNullResultValue())
        {
            await InvokeAsync(LoadPeers);
        }
    }

    private async Task UnlockPrivateKey(char[] passphrase)
    {
        await Mediator.Send(new SetMasterPassphraseCommand(passphrase));
        Array.Clear(passphrase);
    }

    private Task LockPrivateKey() => Mediator.Send(new RemoveMasterPassphraseCommand());

    private Task ReloadPeerConnections() => Mediator.Send(new InvokeNetworkBridgeCommand());

    public void Dispose()
    {
        DashboardUIState.OnInboundPeersChanged -= OnPeersChanged;
        DashboardUIState.OnOutboundPeersChanged -= OnPeersChanged;
    }
}
