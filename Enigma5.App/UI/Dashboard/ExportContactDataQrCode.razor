@using Enigma5.App.Common.Extensions
@using Enigma5.App.Models
@using Enigma5.Security.Contracts

@inject IConfiguration Configuration
@inject ICertificateManager CertificateManager

<div class="card shadow">
    <img class="card-image-top" src="@QrCode" alt="image">
    <div class="card-body">
        <p class="card-text">Scan QR code to connect to this server</p>
    </div>
</div>

@code {
    private string QrCode
    => new ExportedContactDataDto
    {
        Host = Configuration.GetHostname(),
        OnionService = Configuration.GetOnionService(),
        Address = CertificateManager.Address,
        PublicKey = CertificateManager.PublicKey
    }.ToQrCode();
}
