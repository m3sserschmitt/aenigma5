{
  "ConnectionStrings": {
    "DbConnectionString": "data source=/var/lib/aenigma/db/aenigmaDb.sqlite"
  },
  "Kestrel": {
    "EndPoints": {
      "Http": {
        "Url": "http://127.0.0.1:8080"
      },
      "HttpAuthorized": {
        "Url": "http://127.0.0.1:8081"
      }
    }
  },
  "OnionService": null,
  "KeySource": "File",
  "PassphraseSource": "Azure",
  "AzureVaultUrl": null,
  "PrivateKeyPath": "/usr/local/etc/aenigma/private-key.pem",
  "PublicKeyPath": "/usr/local/etc/aenigma/public-key.pem",
  "PassphrasePath": null,
  "WebContentDirectory": "/srv/aenigma/uploads",
  "MessageRetentionPeriod": "07.00:00:00",
  "SentMessageRetentionPeriod": "01.00:00:00",
  "SharedDataRetentionPeriod": "07.00:00:00",
  "FilesRetentionPeriod": "07.00:00:00",
  "Hostname": null,
  "VertexLifetime": "00:30:00",
  "Network": {
    "RetryConnections": true,
    "ConnectionRetriesCount": 1000000,
    "DelayBetweenConnectionRetries": 5000
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Error",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Error",
        "Microsoft.Hosting.Lifetime": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "/var/log/aenigma/aenigma-logs-.txt",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  }
}
