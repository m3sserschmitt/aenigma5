{
  "ConnectionStrings": {
    "DbConnectionString": "data source=aenigmaDb.sqlite"
  },
  "Kestrel": {
    "EndPoints": {
      "Http": {
        "Url": "http://localhost:8080"
      }
    }
  },
  "OnionService": null,
  "KeySource": "File",
  "PassphraseSource": "Dashboard",
  "AzureVaultUrl": null,
  "PrivateKeyPath": "private-key.pem",
  "PublicKeyPath": "public-key.pem",
  "PassphrasePath": null,
  "WebContentDirectory": "./",
  "MessageRetentionPeriod": "07.00:00:00",
  "SentMessageRetentionPeriod": "01.00:00:00",
  "SharedDataRetentionPeriod": "07.00:00:00",
  "FilesRetentionPeriod": "07.00:00:00",
  "Hostname": "http://localhost:8080",
  "LeafsLifetime": "03.00:00:00",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Error",
        "Microsoft.Hosting.Lifetime": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/logs-.txt",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  }
}