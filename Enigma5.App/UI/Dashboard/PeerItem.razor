@using Enigma5.App.Models

<div class="list-group-items-action card shadow">
    <div class="card-body">
        <div class="row">
            <div class="col col-6">
                Host: <strong>@Model.Host</strong>
            </div>
            <div class="col col-5">
                Address: <strong>@Model.Address</strong>
            </div>
            <div class="col col-1">
                <button class="btn btn-danger" @onclick="Remove">Remove</button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public required Peer Model { get; set; }
    [Parameter] public EventCallback<Peer> OnRemove { get; set; } = default;

    private Task Remove() => OnRemove.InvokeAsync(Model);
}