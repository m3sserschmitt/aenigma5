@using Enigma5.App.Models
@using Enigma5.App.UI.Common

@rendermode InteractiveServer
@implements IDisposable
@inject DashboardUIState DashboardUIState

<div class="h-100 card shadow">
    <div class="d-flex flex-column card-body">
        <div class="flex-grow-1">
            <h3 class="card-text">Connected Peers</h3>
            @if (Items.Count() > 0)
            {
                <button class="btn btn-primary rounded-pill" @onclick="Retry" disabled="@(!PrivateKeyUnlocked)">Retry</button>
                <ItemsList Items="Items">
                    <PeerItem Model="context" OnRemove="OnRemoveItem" />
                </ItemsList>
            }
            else
            {
                <p class="card-text text-muted">No items available.</p>
            }
        </div>
        <div class="row">
            <div class="col col-6">
                <label for="host-input">Host (Onion Service)</label>
                <InputText id="host-input" class="form-control" @bind-Value="@Host" placeholder="Enter host here..."
                    disabled="@(!PrivateKeyUnlocked)" />
            </div>
            <div class="col col-5">
                <label for="address-input">Peer Address</label>
                <InputText id="address-input" class="form-control" @bind-Value="@Address"
                    placeholder="Enter peer address here..." disabled="@(!PrivateKeyUnlocked)" />
            </div>
            <div class="col col-1 d-flex align-items-end justify-content-center">
                <button class="btn btn-primary rounded-pill" @onclick="AddItem"
                    disabled="@(!PrivateKeyUnlocked)">Add</button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public IEnumerable<PeerDto> Items { get; set; } = [];
    [Parameter] public EventCallback<PeerDto> OnAddItem { get; set; } = default;
    [Parameter] public EventCallback<PeerDto> OnRemoveItem { get; set; } = default;
    [Parameter] public EventCallback OnRetry { get; set; } = default;

    private string Host = string.Empty;
    private string Address = string.Empty;
    private bool PrivateKeyUnlocked = false;

    protected override Task OnInitializedAsync()
    {
        DashboardUIState.OnPrivateKeyUnlockedChanged += OnPrivateKeyUnlockedChanged;
        return Task.CompletedTask;
    }

    private void OnPrivateKeyUnlockedChanged(bool unlocked) => InvokeAsync(() =>
    {
        PrivateKeyUnlocked = unlocked;
    });

    private Task AddItem()
    {
        if (string.IsNullOrEmpty(Host) || string.IsNullOrWhiteSpace(Address))
        {
            return Task.CompletedTask;
        }
        var newPeer = new PeerDto
        {
            Host = Host,
            Address = Address
        };
        ResetInput();
        return OnAddItem.InvokeAsync(newPeer);
    }

    private void ResetInput()
    {
        Host = string.Empty;
        Address = string.Empty;
    }

    private Task Retry() => OnRetry.InvokeAsync();

    public void Dispose()
    {
        DashboardUIState.OnPrivateKeyUnlockedChanged -= OnPrivateKeyUnlockedChanged;
    }
}